# ==============================================================================
# Variables de entorno — [NOMBRE_DEL_PROYECTO]
# ==============================================================================
# Copia este archivo a `.env` y completa los valores para tu entorno.
#   cp .env.example .env
#
# NUNCA subas tu archivo `.env` con valores reales al repositorio.
# Ver SECURITY.md y docs/conventions/secrets.md.
# ==============================================================================

# ── Entorno ───────────────────────────────────────────────────────────────
# Entorno de ejecución: development | staging | production
APP_ENV=development
# Puerto en el que escucha la aplicación
PORT=3000

# ── Base de datos ─────────────────────────────────────────────────────────
# Cadena de conexión a la base de datos principal
DATABASE_URL=

# ── Autenticación ─────────────────────────────────────────────────────────
# Secreto para firmar tokens/sesiones (genera uno aleatorio y largo)
AUTH_SECRET=
# Tiempo de expiración de los tokens
AUTH_TOKEN_TTL=7d

# ── APIs / servicios externos ─────────────────────────────────────────────
# Clave y URL del servicio externo [SERVICIO/API]
API_KEY=
API_URL=

# ── Logging ───────────────────────────────────────────────────────────────
# Nivel de log: debug | info | warn | error
LOG_LEVEL=info

# ── [OTRAS_VARIABLES] ─────────────────────────────────────────────────────
